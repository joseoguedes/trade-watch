<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- MENU HOVER BRUSHES -->
    <SolidColorBrush x:Key="MenuItemHoverBrush" Color="#0E3F3B" />
    <SolidColorBrush x:Key="MenuItemOpenBrush" Color="#156E68" />

    <!-- SUBMENU BRUSHES -->
    <SolidColorBrush x:Key="SubMenuBgBrush" Color="#0A2F2C" />
    <SolidColorBrush x:Key="SubMenuBorderBrush" Color="#156E68" />
    <SolidColorBrush x:Key="SubMenuFgBrush" Color="White" />
    <SolidColorBrush x:Key="SubMenuHoverBgBrush" Color="#114843" />

    <!-- STATUS BAR FOOTER -->
    <SolidColorBrush x:Key="StatusBarBgBrush" Color="#0A1E1C" />
    <SolidColorBrush x:Key="StatusBarFgBrush" Color="#778888" />

    <!-- NEXT TO OPEN BAR -->
    <SolidColorBrush x:Key="NextToOpenBarBgBrush" Color="#0A1E1C" />
    <SolidColorBrush x:Key="NextToOpenBarBorderBrush" Color="#1A4A44" />
    <SolidColorBrush x:Key="NextToOpenBarLabelBrush" Color="#778888" />
    <SolidColorBrush x:Key="NextToOpenBarNameBrush" Color="#0aff9d" />
    <SolidColorBrush x:Key="NextToOpenBarCountdownBrush" Color="White" />

    <!-- DARK THEME SCROLLBAR BRUSHES -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#333333" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#0aff9d" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#15ffb3" />
    <SolidColorBrush x:Key="ScrollBarThumbDraggingBrush" Color="#00cc88" />
    <SolidColorBrush x:Key="ScrollBarButtonBrush" Color="#111111" />
    <SolidColorBrush x:Key="ScrollBarArrowBrush" Color="#BBBBBB" />

</ResourceDictionary>
