<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- MENU HOVER BRUSHES -->
    <SolidColorBrush x:Key="MenuItemHoverBrush" Color="#4A7CAA" />
    <SolidColorBrush x:Key="MenuItemOpenBrush" Color="#3D6E9E" />

    <!-- SUBMENU BRUSHES -->
    <SolidColorBrush x:Key="SubMenuBgBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SubMenuBorderBrush" Color="#5B8DB8" />
    <SolidColorBrush x:Key="SubMenuFgBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="SubMenuHoverBgBrush" Color="#D0E4F4" />

    <!-- STATUS BAR FOOTER -->
    <SolidColorBrush x:Key="StatusBarBgBrush" Color="#E8F4F0" />
    <SolidColorBrush x:Key="StatusBarFgBrush" Color="#607070" />

    <!-- NEXT TO OPEN BAR -->
    <SolidColorBrush x:Key="NextToOpenBarBgBrush" Color="#EEF4FB" />
    <SolidColorBrush x:Key="NextToOpenBarBorderBrush" Color="#BDD0E8" />
    <SolidColorBrush x:Key="NextToOpenBarLabelBrush" Color="#5A6A7A" />
    <SolidColorBrush x:Key="NextToOpenBarNameBrush" Color="#1A5A90" />
    <SolidColorBrush x:Key="NextToOpenBarCountdownBrush" Color="#1A2A3A" />

    <!-- LIGHT THEME SCROLLBAR BRUSHES -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#D8EAFA" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#7FB4D8" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#5A9AC4" />
    <SolidColorBrush x:Key="ScrollBarThumbDraggingBrush" Color="#3D7EA8" />
    <SolidColorBrush x:Key="ScrollBarButtonBrush" Color="#C8DFF0" />
    <SolidColorBrush x:Key="ScrollBarArrowBrush" Color="#2A5A7A" />

</ResourceDictionary>
