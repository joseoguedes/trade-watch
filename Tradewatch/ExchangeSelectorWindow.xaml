<Window x:Class="Tradewatch.ExchangeSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Exchanges"
        Height="450" Width="400"
        Background="#111111"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        MinHeight="300"
        MinWidth="350">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- SEARCH BOX with inline placeholder -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBox x:Name="SearchBox"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,5"
                     FontSize="13"
                     Background="#1E1E1E"
                     Foreground="White"
                     CaretBrush="White"
                     BorderBrush="#444"
                     BorderThickness="1"/>
            <TextBlock Text="Search exchanges..."
                       IsHitTestVisible="False"
                       Foreground="#888888"
                       Padding="8,6"
                       FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- SCROLLABLE EXCHANGE LIST -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ItemsView}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                  Margin="0,5"
                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- BOTTOM BUTTONS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button x:Name="AddAllBtn"
                    Content="Add all"
                    Width="80"
                    Margin="5"
                    Command="{Binding SelectAllCommand}"
                    Background="#333"
                    Foreground="White" />

            <Button x:Name="RemoveAllBtn"
                    Content="Remove all"
                    Width="90"
                    Margin="5"
                    Command="{Binding ClearAllCommand}"
                    Background="#333"
                    Foreground="White" />

            <Button x:Name="CancelBtn"
                    Content="Close"
                    Width="80"
                    Margin="5"
                    Command="{Binding CancelCommand}"
                    Background="#333"
                    Foreground="White" />

            <Button x:Name="SaveBtn"
                    Content="Save"
                    Width="80"
                    Margin="5"
                    Command="{Binding SaveCommand}"
                    Background="#0E4E4A"
                    Foreground="White"
                    FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>
