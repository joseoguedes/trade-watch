<Window x:Class="Tradewatch.ExchangeSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Exchanges"
        Height="450" Width="400"
        Background="#111111"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        MinHeight="300"
        MinWidth="350">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- SEARCH BOX -->
        <TextBox x:Name="SearchBox"
                 Grid.Row="0"
                 Margin="0,0,0,8"
                 Padding="6,5"
                 FontSize="13"
                 Background="#1E1E1E"
                 Foreground="White"
                 CaretBrush="White"
                 BorderBrush="#444"
                 BorderThickness="1"
                 Tag="Search exchanges..."
                 TextChanged="SearchBox_TextChanged"
                 GotFocus="SearchBox_GotFocus"
                 LostFocus="SearchBox_LostFocus" />

        <!-- SCROLLABLE EXCHANGE LIST -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ExchangeList" />
        </ScrollViewer>

        <!-- BOTTOM BUTTONS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            
            <Button x:Name="AddAllBtn"
                    Content="Add all"
                    Width="80"
                    Margin="5"
                    Click="SelectAll_Click"
                    Background="#333"
                    Foreground="White" />

            <Button x:Name="RemoveAllBtn"
                    Content="Remove all"
                    Width="90"
                    Margin="5"
                    Click="ClearAll_Click"
                    Background="#333"
                    Foreground="White" />

            <Button x:Name="CancelBtn"
                    Content="Cancel"
                    Width="80"
                    Margin="5"
                    Click="Cancel_Click"
                    Background="#333"
                    Foreground="White" />

            <Button x:Name="SaveBtn"
                    Content="Save"
                    Width="80"
                    Margin="5"
                    Click="Save_Click"
                    Background="#0E4E4A"
                    Foreground="White"
                    FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>